# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_analytics
DB_USER=postgres
DB_PASSWORD=your_password_here

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=analytics@yourcompany.com
EMAIL_TO=manager@yourcompany.com,executive@yourcompany.com

# Paths
DATA_DIR=./data
REPORTS_DIR=./reports
LOGS_DIR=./logs

# Analytics Settings
FORECAST_MONTHS=3
LOW_SELLER_THRESHOLD=10
STOCK_COVERAGE_WARNING_DAYS=14
